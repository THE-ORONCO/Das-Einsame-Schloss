dialogs = {
"FIRST_DIALOG_1": {
"default": "“Release me! I beg of you!\"",
"en": ""
},
"FIRST_DIALOG_10": {
"default": "“You could? Please do so! I CANNOT ENDURE THIS PAIN ANY LONGER.”",
"en": ""
},
"FIRST_DIALOG_11": {
"default": "“Who are you?”",
"en": ""
},
"FIRST_DIALOG_12": {
"default": "“Ar-are you actually a real ghost?",
"en": ""
},
"FIRST_DIALOG_13": {
"default": "“AAAAAAAAAAAAAAAAAH”",
"en": ""
},
"FIRST_DIALOG_14": {
"default": "“Where are the rest of the castle’s inhabitants?”",
"en": ""
},
"FIRST_DIALOG_15": {
"default": "“How long have you been haunting this place?”",
"en": ""
},
"FIRST_DIALOG_16": {
"default": "“Yes, my husband. It is him that I had longed for the most.”",
"en": ""
},
"FIRST_DIALOG_17": {
"default": "“Yes, but I feel as if they aren’t the only thing keeping me tied to this place.”
",
"en": ""
},
"FIRST_DIALOG_18": {
"default": "“I wouldn’t know. It has been so long, I have lost track of time.”
",
"en": ""
},
"FIRST_DIALOG_19": {
"default": "“I can unlock those chains for you.”",
"en": ""
},
"FIRST_DIALOG_2": {
"default": "“I am the lady of this castle. Well, I used to be. Now, I am just an apparition - a shell of my former self.”",
"en": ""
},
"FIRST_DIALOG_3": {
"default": " “I… I believe so. I am aware of my surroundings, I am aware of myself. But still, I do not feel a thing… and I remember my death?”
",
"en": ""
},
"FIRST_DIALOG_4": {
"default": "“Be not afraid, for I mean you no harm. I only want to rest peacefully.”
",
"en": ""
},
"FIRST_DIALOG_5": {
"default": "“I was the last remaining inhabitant of the castle. My last few years were… grueling. It is all too hazy now, the only feeling I remember is pain, sorrow and anguish. If I could be sure, I would say that I died from a broken heart or perhaps loneliness. Is it even possible to die in such a way?”
",
"en": ""
},
"FIRST_DIALOG_6": {
"default": "“How did you die?”",
"en": ""
},
"FIRST_DIALOG_7": {
"default": " “They all perished long before I did. They all ascended and left this world for another. I, however, cannot seem to be able to do so.”
",
"en": ""
},
"FIRST_DIALOG_8": {
"default": "“Is there anybody you remember?”",
"en": ""
},
"FIRST_DIALOG_9": {
"default": "“Are these chains holding you captive?”",
"en": ""
},
"FIRST_OPT1_1": {
"default": "“Who are you?”"
},
"FIRST_OPT1_2": {
"default": "“Ar-are you actually a real ghost?”"
},
"FIRST_OPT1_3": {
"default": "“AAAAAAAAAAAAAAAAAH”"
},
"FIRST_OPT2_1": {
"default": "“How did you die?”"
},
"FIRST_OPT2_2": {
"default": "“Where are the rest of the castle’s inhabitants?”"
},
"FIRST_OPT3_1": {
"default": "“Is there anybody you remember?”"
},
"FIRST_OPT3_2": {
"default": "“Are these chains holding you captive?”"
},
"FIRST_OPT3_3": {
"default": "“How long have you been haunting this place?”"
}
}
