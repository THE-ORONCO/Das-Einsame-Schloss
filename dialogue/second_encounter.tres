dialogs = {
"SECOND_DIALOG_1": {
"default": "“YOU DID IT! YOU SET ME FREE!\" 
\"But, why isn't anything happening?\"
\"No… \"
\"Could I still bound to the castle…?\"",
"en": ""
},
"SECOND_DIALOG_10": {
"default": "“I need more information about your engagement ring.”",
"en": ""
},
"SECOND_DIALOG_11": {
"default": "“Alright, I’ll get to work.”",
"en": ""
},
"SECOND_DIALOG_2": {
"default": "“I am sensing a connection to three objects from my past.\" 
\"A necklace,\" 
\"a pair of glasses\" 
\"and my engagement ring.\" 
\"Try finding those three items.\"
\"I believe they are somewhere in the castle.”
",
"en": ""
},
"SECOND_DIALOG_3": {
"default": "“It was a gift from my husband.\"
\"It was beautiful.\" 
\"It reminded me of warmth, for some strange reason.\"
",
"en": ""
},
"SECOND_DIALOG_4": {
"default": "“I don’t recall being short sighted.\"
\"But I remember using a pair of glasses when viewing art.” ",
"en": ""
},
"SECOND_DIALOG_5": {
"default": "“I don’t remember wearing it.\"
\"But oddly, I think of porcelain whenever I am reminded of it.”",
"en": ""
},
"SECOND_DIALOG_6": {
"default": "“Thank you and good luck!”",
"en": ""
},
"SECOND_DIALOG_7": {
"default": "“Any idea what could be keeping you  bound?”",
"en": ""
},
"SECOND_DIALOG_8": {
"default": "“Tell me more about the necklace.”",
"en": ""
},
"SECOND_DIALOG_9": {
"default": "“I would like to know more about the glasses.”",
"en": ""
},
"SECOND_OPT2_1": {
"default": "“Tell me more about the necklace.”"
},
"SECOND_OPT2_2": {
"default": "“I would like to know more about the glasses.”"
},
"SECOND_OPT2_3": {
"default": "“I need more information about your engagement ring.”"
},
"SECOND_OPT2_4": {
"default": "“Alright, I’ll get to work.”"
}
}
